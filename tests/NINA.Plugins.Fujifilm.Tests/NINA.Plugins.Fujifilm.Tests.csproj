<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Configuration\CameraConfig.cs" Link="Source\CameraConfig.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Configuration\CameraModelRules.cs" Link="Source\CameraModelRules.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Devices\FujifilmShutterSpeedCatalog.cs" Link="Source\FujifilmShutterSpeedCatalog.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Devices\FujifilmBatteryProtocol.cs" Link="Source\FujifilmBatteryProtocol.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Devices\LiveView\LiveViewEnums.cs" Link="Source\LiveViewEnums.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Imaging\FujiMetadataValueParser.cs" Link="Source\FujiMetadataValueParser.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Imaging\BayerPaddingCropper.cs" Link="Source\BayerPaddingCropper.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Imaging\SyntheticBayerConverter.cs" Link="Source\SyntheticBayerConverter.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Interop\Native\FujifilmCameraSession.cs" Link="Source\FujifilmCameraSession.cs" />
    <Compile Include="..\..\src\NINA.Plugins.Fujifilm\Settings\FujiSettings.cs" Link="Source\FujiSettings.cs" />
    <None Include="..\..\src\NINA.Plugins.Fujifilm\Configuration\Assets\CameraConfigs\*.json"
          Link="TestData\CameraConfigs\%(Filename)%(Extension)"
          CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
