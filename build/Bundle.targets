<Project>
  <PropertyGroup>
    <DistDir>$(MSBuildThisFileDirectory)..\dist\</DistDir>
    <EnableZipPackaging Condition="'$(MSBuildRuntimeType)' == 'Full'">true</EnableZipPackaging>
  </PropertyGroup>

  <Target Name="PrepareFujifilmPluginPublish" AfterTargets="Build">
    <PropertyGroup>
      <PluginPublishDir>$(TargetDir)publish\</PluginPublishDir>
    </PropertyGroup>
    <ItemGroup>
      <PublishRootItems Include="$(TargetPath)" />
      <PublishRootItems Include="$(TargetDir)plugin.json" />
      <PublishRootItems Include="$(TargetDir)LibRawWrapper.dll" />
      <PublishRootItems Include="$(TargetDir)libraw.dll" />
      <PublishRootItems Include="$(TargetDir)XAPI.dll" Condition="Exists('$(TargetDir)XAPI.dll')" />
      <PublishRootItems Include="$(TargetDir)XSDK.DAT" Condition="Exists('$(TargetDir)XSDK.DAT')" />
      <PublishRootItems Include="$(TargetDir)FTLPTP.dll" Condition="Exists('$(TargetDir)FTLPTP.dll')" />
      <PublishRootItems Include="$(TargetDir)FTLPTPIP.dll" Condition="Exists('$(TargetDir)FTLPTPIP.dll')" />
      <PublishRootItems Include="$(TargetDir)FF????API.dll" />
      <PublishCameraConfigs Include="$(TargetDir)Configuration\Assets\CameraConfigs\*.json" />
    </ItemGroup>

    <RemoveDir Directories="$(PluginPublishDir)" />
    <MakeDir Directories="$(PluginPublishDir)" />
    <MakeDir Directories="$(PluginPublishDir)Configuration\Assets\CameraConfigs" />
    <Copy SourceFiles="@(PublishRootItems)" DestinationFolder="$(PluginPublishDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(PublishCameraConfigs)"
          DestinationFiles="@(PublishCameraConfigs->'$(PluginPublishDir)Configuration\Assets\CameraConfigs\%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <UsingTask TaskName="CreateZip" TaskFactory="CodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll" Condition="'$(EnableZipPackaging)' == 'true'">
    <ParameterGroup>
      <SourceDir ParameterType="System.String" Required="true" />
      <ZipPath ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Reference Include="System.IO.Compression" />
      <Reference Include="System.IO.Compression.FileSystem" />
      <Using Namespace="System.IO.Compression" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        if (File.Exists(ZipPath))
        {
            File.Delete(ZipPath);
        }
        ZipFile.CreateFromDirectory(SourceDir, ZipPath, CompressionLevel.Optimal, false);
      ]]></Code>
    </Task>
  </UsingTask>

  <Target Name="PackagePlugin" AfterTargets="PrepareFujifilmPluginPublish" Condition="'$(EnableZipPackaging)' == 'true'">
    <Error Condition="!Exists('$(PluginPublishDir)XAPI.dll')"
           Text="Cannot package a usable plugin without the Fujifilm Shooting SDK. Set FujifilmSdkDir to the extracted x64 runtime directory." />
    <Error Condition="!Exists('$(PluginPublishDir)FF0002API.dll')"
           Text="The SDK runtime does not contain FF0002API.dll, which is required for legacy X-T2 support." />
    <MakeDir Directories="$(DistDir)" />
    <PropertyGroup>
      <ZipFile>$(DistDir)NINA.Plugins.Fujifilm-$(Configuration).zip</ZipFile>
    </PropertyGroup>
    <CreateZip SourceDir="$(PluginPublishDir)" ZipPath="$(ZipFile)" />
  </Target>
</Project>
